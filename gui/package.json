{
  "name": "vexor-desktop",
  "private": true,
  "version": "0.19.0",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "electron:dev": "node electron/dev-runner.cjs",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && npm run electron:dev\"",
    "build": "vite build",
    "start": "electron .",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make"
  },
  "dependencies": {
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "tar": "7.5.19",
    "tmp": "0.2.7"
  }
}
